# =============================================================================
# CONFIGURAÇÕES DAS APIs
# =============================================================================

### API Principal ###
## PRODUÇÃO (Firebase Cloud Functions)
API_BASE_URL=https://us-central1-flutter-template-app-dev-20817.cloudfunctions.net/api

## DESENVOLVIMENTO (Firebase Emulator)
# API_BASE_URL=http://127.0.0.1:5001/flutter-template-app-dev-20817/us-central1/api

# =============================================================================
# CONFIGURAÇÕES GERAIS DO APP
# =============================================================================

# Controla se os dados devem ser mockados (true) ou consumidos da API real (false)
# Em produção, mantenha como false
USE_MOCK=false
